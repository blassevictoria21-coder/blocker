# Database Configuration
DATABASE_URL=postgresql://spam_user:spam_password@postgres:5432/spam_blocker
DB_HOST=postgres
DB_PORT=5432
DB_NAME=spam_blocker
DB_USER=spam_user
DB_PASSWORD=spam_password

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d

# API Configuration
API_PORT=5000
API_HOST=0.0.0.0
NODE_ENV=production

# Gmail API Configuration (Optional)
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REDIRECT_URI=http://localhost:5000/auth/gmail/callback

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:5000

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Logging
LOG_LEVEL=info
